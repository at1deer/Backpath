{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modalpathethics.com/backpath/schemas/backpath-replay.v1.schema.json",
  "title": "Backpath Replay File v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "operation",
    "manifest",
    "inputs"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "operation": {
      "type": "string"
    },
    "manifest": {},
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "expected": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
