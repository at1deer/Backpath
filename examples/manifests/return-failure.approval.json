{
  "version": 1,
  "operation": "return-failure",
  "name": "Approval boolean reconstructs guessed enum",
  "source": {
    "schema": "../schemas/approval-source.schema.json",
    "corpus": [
      "../corpus/approval_manual.json",
      "../corpus/approval_automatic.json"
    ],
    "equivalence": {
      "mode": "exact"
    }
  },
  "forward": {
    "argv": [
      "node",
      "../transforms/approval_up.js"
    ],
    "timeoutMs": 2000
  },
  "target": {
    "schema": "../schemas/approval-target.schema.json",
    "equivalence": {
      "mode": "exact"
    }
  },
  "reverse": {
    "argv": [
      "node",
      "../transforms/approval_down_guess_manual.js"
    ],
    "timeoutMs": 2000
  },
  "memory": {
    "mode": "none"
  },
  "context": {
    "reverseIsolation": "fresh-process-clean-tempdir"
  },
  "search": {
    "mode": "corpus",
    "budget": 1000,
    "seed": 918273
  },
  "shrink": {
    "enabled": true,
    "budget": 5000,
    "preserveClassification": true
  },
  "replay": {
    "forward": 3,
    "reverse": 3,
    "equivalence": 3
  }
}
