{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Noisy Status Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "enum": [
        "pending_review",
        "active",
        "closed"
      ]
    },
    "requestId": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region": {
          "type": "string"
        },
        "attempts": {
          "type": "integer"
        },
        "flagged": {
          "type": "boolean"
        }
      }
    }
  }
}
